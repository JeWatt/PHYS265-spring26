def burn_time(m0: float, mf: float, mdot: float) -> float:
    """
    Compute rocket burn time.

    Parameters
    ----------
    m0 : float
        Initial wet mass (kg)
    mf : float
        Final dry mass (kg)
    mdot : float
        Fuel burn rate (kg/s)

    Outputs
    -------
    float
        Burn time T (seconds)
    """
    if m0 <= mf:
        raise ValueError("Wet mass must be greater than dry mass")

    if mdot <= 0:
        raise ValueError("Burn rate must be positive")

    T = (m0 - mf) / mdot
    return T


