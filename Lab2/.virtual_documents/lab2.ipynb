class BreitWignerFit:
    def __init__(self, masses):
        self.masses = masses

    def breit_wigner(self, m, A, m0, gamma):
        return A * (gamma**2) / ((m - m0)**2 + (gamma/2)**2)

    def fit(self):
        bins = np.linspace(80, 100, 41)
        counts, edges = np.histogram(self.masses, bins=bins)
        centers = 0.5 * (edges[:-1] + edges[1:])
        errors = np.sqrt(counts)

        #Avoid zero-error bins
        mask = counts > 0

        popt, pcov = curve_fit(self.breit_wigner, centers[mask], counts[mask], sigma=errors[mask], p0=[max(counts), 91, 2.5], absolute_sigma=True)

        return centers, counts, errors, popt, pcov
    def plot(self): #I should have just saved the previous plot as an object and replotted that but copying and pasting my function with added functionality works too
        centers, counts, errors, popt, pcov= self.fit()
        A, m0, gamma = popt

        bins = np.linspace(80, 100, 41)
        width = bins[1] - bins[0]

        plt.figure()

        #hist
        plt.bar(centers, counts, width=width, align='center', alpha=0.6, edgecolor='black', label='Data', color='yellow')

        #error bars
        plt.errorbar(centers, counts, yerr=errors, fmt='none', ecolor='black', capsize=2)

        #smoove curve using bar as approximation) plt.bar is carrying me here
        fine_m = np.linspace(80, 100, 400)
        fit_vals = self.breit_wigner(fine_m, A, m0, gamma)

        plt.bar(fine_m, fit_vals, width=0.05, alpha=0.3, label='Breit-Wigner Fit', color='red')

        plt.xlabel("Invariant Mass (GeV)")
        plt.ylabel("Counts")
        plt.title(f"Fit Results: m0={m0:.2f} GeV, Γ={gamma:.2f} GeV")
        plt.legend()

        plt.show()

fitter = BreitWignerFit(masses)
fitter.plot()





