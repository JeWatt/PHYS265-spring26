class InvariantMassCalculator:
    def __init__(self, filename):
        self.filename = filename
        self.data = None

    def load_data(self):
        self.data = np.loadtxt(self.filename, delimiter=",", skiprows=1)

        # Columns (based on lab description)
        self.pt1 = self.data[:, 0]
        self.pt2 = self.data[:, 1]
        self.eta1 = self.data[:, 2]
        self.eta2 = self.data[:, 3]
        self.phi1 = self.data[:, 4]
        self.phi2 = self.data[:, 5]
        self.E1 = self.data[:, 6]
        self.E2 = self.data[:, 7]

    def compute_momentum_components(self, pt, eta, phi):
        px = pt * np.cos(phi)
        py = pt * np.sin(phi)
        pz = pt * np.sinh(eta)
        return px, py, pz

    def compute_invariant_mass(self):
        # Lepton 1
        px1, py1, pz1 = self.compute_momentum_components(
            self.pt1, self.eta1, self.phi1
        )

        # Lepton 2
        px2, py2, pz2 = self.compute_momentum_components(
            self.pt2, self.eta2, self.phi2
        )

        # Total 4-momentum
        E_total = self.E1 + self.E2
        px_total = px1 + px2
        py_total = py1 + py2
        pz_total = pz1 + pz2

        # Invariant mass
        mass = np.sqrt(
            E_total**2 - (px_total**2 + py_total**2 + pz_total**2)
        )

        return mass


class HistogramPlotter:
    def __init__(self, masses):
        self.masses = masses

    def plot_histogram(self):
        # Bin setup (as required)
        bins = np.linspace(80, 100, 41)

        counts, edges = np.histogram(self.masses, bins=bins)
        centers = 0.5 * (edges[:-1] + edges[1:])

        # Poisson errors
        errors = np.sqrt(counts)

        # Plot using BAR (not plt.plot)
        plt.figure()

        plt.bar(
            centers,
            counts,
            width=(edges[1] - edges[0]),
            align='center',
            alpha=0.7,
            edgecolor='black',
            label='Data'
        )

        # Error bars (this is allowed — not plt.plot)
        plt.errorbar(
            centers,
            counts,
            yerr=errors,
            fmt='none',
            ecolor='black',
            capsize=2
        )

        plt.xlabel("Invariant Mass (GeV)")
        plt.ylabel("Counts")
        plt.title("Invariant Mass Distribution")
        plt.legend()

        plt.show()


def main():
    calc = InvariantMassCalculator("atlas_z_to_ll.csv")
    calc.load_data()

    masses = calc.compute_invariant_mass()

    plotter = HistogramPlotter(masses)
    plotter.plot_histogram()

























