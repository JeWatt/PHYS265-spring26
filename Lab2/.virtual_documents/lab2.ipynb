# =========================
def compute_chi_squared(self, centers, counts, errors, popt):
    A, m0, gamma = popt

    mask = counts > 0

    expected = self.breit_wigner(centers[mask], A, m0, gamma)
    observed = counts[mask]
    sigma = errors[mask]

    chi2 = np.sum(((observed - expected) ** 2) / (sigma ** 2))
    dof = len(observed) - len(popt)
    chi2_red = chi2 / dof

    return chi2, chi2_red

#this method contains improvements to plot and labelling for 3, Will also prints a summary of results for Problem 4
def patched_plot(self):
    centers, counts, errors, popt, pcov = self.fit()

    A, m0, gamma = popt
    perr = np.sqrt(np.diag(pcov))
    dA, dm0, dgamma = perr

    chi2, chi2_red = self.compute_chi_squared(centers, counts, errors, popt)

    self.report_results(centers, counts, errors, popt, pcov)

    bins = np.linspace(80, 100, 41)
    width = bins[1] - bins[0]

    plt.figure()

    plt.bar(centers, counts, width=width, alpha=0.6, edgecolor='black', color='yellow')
    plt.errorbar(centers, counts, yerr=errors, fmt='none', capsize=2)

    fine_m = np.linspace(80, 100, 400)
    fit_vals = self.breit_wigner(fine_m, A, m0, gamma)

    plt.bar(fine_m, fit_vals, width=0.05, alpha=0.3, color='red')

    plt.xlabel("Invariant Mass (GeV)")
    plt.ylabel("Counts")

    plt.title(f"m0={m0:.2f}±{dm0:.2f} GeV | Γ={gamma:.2f}±{dgamma:.2f} GeV | χ²ν={chi2_red:.2f}")

    plt.show()
def report_results(self, centers, counts, errors, popt, pcov):
    A, m0, gamma = popt
    perr = np.sqrt(np.diag(pcov))
    dA, dm0, dgamma = perr

    chi2, chi2_red = self.compute_chi_squared(centers, counts, errors, popt)

    print("\n===== Fit Results =====")
    print(f"m0 = {m0:.3f} ± {dm0:.3f} GeV")
    print(f"Gamma = {gamma:.3f} ± {dgamma:.3f} GeV")
    print(f"Chi-squared = {chi2:.2f}")
    print(f"Reduced Chi-squared = {chi2_red:.2f}")

    Z_MASS_TRUE = 91.1876
    Z_WIDTH_TRUE = 2.495

    print("\n===== Comparison =====")
    print(f"Mass difference: {m0 - Z_MASS_TRUE:.3f} GeV")
    print(f"Width difference: {gamma - Z_WIDTH_TRUE:.3f} GeV")


#here is where I apply the monkey patch(add/update existing functions in my class)
BreitWignerFit.compute_chi_squared = compute_chi_squared
BreitWignerFit.plot = patched_plot
BreitWignerFit.report_results = report_results

