def uniform_earth_tunnel_rhs(t: float, state: ArrayLike) -> list[float]:
    """
    Pole-to-pole tunnel through a constant-density Earth.
    s is position measured from Earth's center. s=R is the starting surface.
    """
    s, v = state
    a = -omega_tunnel**2 * s
    return [v, a]


